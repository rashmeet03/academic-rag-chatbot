# ============================================
# Smart Copilot - Environment Configuration
# ============================================
# Copy this file to .env and adjust values.

# --- Application ---
# APP_NAME=Smart Copilot
# LOG_LEVEL=INFO

# --- CORS (comma-separated origins) ---
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Qdrant ---
# QDRANT_PATH=./local_qdrant_db
# COLLECTION_NAME=academic_subjects_hybrid

# --- Embedding Model ---
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIMENSION=384

# --- LLM (Ollama) ---
# LLM_MODEL=llama3.2
# LLM_TEMPERATURE=0.1

# --- Document Processing ---
# MAX_FILE_SIZE_MB=50
# CHUNK_SIZE=400
# CHUNK_OVERLAP=50

# --- Retrieval ---
# RETRIEVAL_LIMIT=5
# SCORE_THRESHOLD=0.30
